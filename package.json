{
  "name": "english-root-zhan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/verify-client-build.mjs",
    "build:check": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "build:pages": "vite build && node scripts/verify-client-build.mjs",
    "build:cf": "vite build && node scripts/verify-client-build.mjs && wrangler deploy",
    "preview": "vite build && wrangler dev",
    "deploy": "yarn build:cf",
    "gen": "node convert-pages-to-json.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "framer-motion": "^12.6.3",
    "hono": "^4.12.23",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "^4.20260527.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.95.0"
  },
  "packageManager": "yarn@4.9.1"
}
